# Supabase ---------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key MUST stay server-only. Used by the API routes for
# privileged operations (sending SMS on behalf of a workspace, etc).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL used to construct the registration link inside SMS.
NEXT_PUBLIC_APP_URL=https://popform.io
