# Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Public URL used for SMS links + Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=https://pingform.io

# Central Twilio (used unless a workspace overrides via BYO settings) ------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp via Twilio (optional). Set the sender to enable automated WhatsApp
# sends; without it the extension falls back to manual click-to-WhatsApp.
# For business-initiated (cold) sends, set an approved template Content SID.
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_CONTENT_SID=

# Central Pusher (managed realtime). When set, every workspace uses this app
# and customers don't need their own keys. Falls back to per-workspace BYO.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe price IDs per plan (create products in the Stripe dashboard).
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PRACTICE=price_xxx
